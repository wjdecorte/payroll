# Copy to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=Payroll
APP_VERSION=1.0.0
DEBUG_MODE=false

# ---------------------------------------------------------------------------
# Database
# SQLite (default — good for single-user local use):
DATABASE_URL=sqlite:///./payroll.db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/payroll
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Logging — "standard" for human-readable, "json" for structured/prod
# ---------------------------------------------------------------------------
API_LOG_TYPE=standard

# ---------------------------------------------------------------------------
# Production server
# ---------------------------------------------------------------------------
WORKERS=2

# ---------------------------------------------------------------------------
# QuickBooks Account Names
# Update these to match your exact chart of accounts in QBO.
# ---------------------------------------------------------------------------
ACCT_OFFICER_COMPENSATION=Officer Compensation
ACCT_PAYROLL_TAX_EXPENSE=Payroll Tax Expense
ACCT_HEALTH_INSURANCE_EXP=Health Insurance Expense
ACCT_HSA_EXPENSE=HSA Contribution Expense
ACCT_FED_TAX_PAYABLE=Federal Income Tax Withholding Payable
ACCT_GA_TAX_PAYABLE=Georgia Income Tax Withholding Payable
ACCT_SS_PAYABLE_EE=Social Security Tax Payable - Employee
ACCT_SS_PAYABLE_ER=Social Security Tax Payable - Employer
ACCT_MEDICARE_PAYABLE_EE=Medicare Tax Payable - Employee
ACCT_MEDICARE_PAYABLE_ER=Medicare Tax Payable - Employer
ACCT_HEALTH_INS_PAYABLE=Health Insurance Payable
ACCT_HSA_PAYABLE=HSA Payable
ACCT_CHECKING=Checking Account
